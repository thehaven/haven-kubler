#!/bin/bash
# Radicale Pre-commit Hook: Automated NLP Categorisation
# This script is called by git before every commit to intelligently tag events.

# Get staged .ics files (Added, Copied, Modified)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.ics$')

if [ -n "$STAGED_FILES" ]; then
    echo "Radicale Hook: Processing staged files for intelligent categorisation..."
    # The venv and script are located in /opt/scripts
    /opt/scripts/venv/bin/python3 /opt/scripts/smart_categorize.py $STAGED_FILES
    
    # Re-add the modified files to the commit
    git add $STAGED_FILES
fi